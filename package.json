{
  "name": "openflash",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:worker": "npx @opennextjs/cloudflare build",
    "preview": "npx @opennextjs/cloudflare build && npx wrangler dev",
    "deploy": "yes | npx wrangler d1 migrations apply openflash-db --remote && npx @opennextjs/cloudflare build && npx wrangler deploy",
    "cf-typegen": "npx wrangler types --env-interface CloudflareEnv",
    "db:migrate:local": "npx wrangler d1 execute openflash-db --local --file=migrations/0001_initial.sql",
    "db:migrate:remote": "npx wrangler d1 execute openflash-db --remote --file=migrations/0001_initial.sql",
    "db:pull": "bash scripts/db-pull.sh",
    "db:push": "bash scripts/db-push.sh",
    "db:push:full": "bash scripts/db-push-full.sh",
    "db:diff": "bash scripts/db-diff.sh"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1",
    "next": "^15",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "pdf-parse": "^2.4.5",
    "postcss": "^8",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4"
  }
}
